  namaJabatan            String    @map("nama_jabatan") @db.VarChar(200)
  jenjang                String    @db.VarChar(30)
  kategori               String    @db.VarChar(20)
  jenjangAwal            String?   @map("jenjang_awal") @db.VarChar(30)
  jenjangPuncak          String?   @map("jenjang_puncak") @db.VarChar(30)
  golonganRuangAwal      String?   @map("golongan_ruang_awal") @db.VarChar(10)
  rumpunJabatan          String?   @map("rumpun_jabatan") @db.VarChar(150)
  ruangLingkup           String?   @map("ruang_lingkup") @db.VarChar(100)
  kedudukan              String?   @db.Text
  pengisianAsn           String?   @map("pengisian_asn") @db.VarChar(50)
  instansiPembina        String?   @map("instansi_pembina") @db.VarChar(200)
  dasarHukum             String?   @map("dasar_hukum") @db.VarChar(200)
  tugasJabatan           String?   @map("tugas_jabatan") @db.Text
  pendidikanPengangkatan String?   @map("pendidikan_pengangkatan") @db.Text
  pendidikanPerpindahan  String?   @map("pendidikan_perpindahan") @db.Text
  perpresTunjangan       String?   @map("perpres_tunjangan") @db.VarChar(200)
  besaranTunjangan       String?   @map("besaran_tunjangan") @db.VarChar(100)

  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  jabatan                SiformenJabatan[]

  @@index([namaJabatan])
  @@index([kategori])
  @@index([rumpunJabatan])
  @@map("siformen_jabatan_fungsional_ref")
}

model SiformenJabatan {
  id                      String                       @id @default(uuid()) @db.VarChar(36)
  kodeJabatan             String                       @unique @map("kode_jabatan") @db.VarChar(40)
  namaJabatan             String                       @map("nama_jabatan") @db.VarChar(200)
  jenisJabatan            String                       @map("jenis_jabatan") @db.VarChar(40)
  eselonLevel             String?                      @map("eselon_level") @db.VarChar(10)
  kelasJabatan            Int?                         @map("kelas_jabatan")
  unitKerja               String                       @map("unit_kerja") @db.VarChar(200)
  satuanKerja             String?                      @map("satuan_kerja") @db.VarChar(200)
  kualifikasiPendidikan   String?                      @map("kualifikasi_pendidikan") @db.Text
  isActive                Boolean                      @default(true) @map("is_active")

  jabatanFungsionalRefId  String?                      @map("jabatan_fungsional_ref_id") @db.VarChar(36)
  jabatanFungsionalRef    SiformenJabatanFungsionalRef? @relation(fields: [jabatanFungsionalRefId], references: [id], onDelete: SetNull)

  createdAt               DateTime                     @default(now()) @map("created_at")
  createdBy               String?                      @map("created_by") @db.VarChar(36)
  updatedAt               DateTime                     @updatedAt @map("updated_at")
  updatedBy               String?                      @map("updated_by") @db.VarChar(36)
  deletedAt               DateTime?                    @map("deleted_at")

  bezetting               SiformenBezetting[]
  formasi                 SiformenFormasi[]
  abk                     SiformenAbk[]

  @@index([jenisJabatan])
  @@index([unitKerja])
  @@index([jabatanFungsionalRefId])
  @@map("siformen_jabatan")
}

model SiformenBezetting {
  id           String           @id @default(uuid()) @db.VarChar(36)
  jabatanId    String?          @map("jabatan_id") @db.VarChar(36)
  jabatan      SiformenJabatan? @relation(fields: [jabatanId], references: [id], onDelete: SetNull)

  namaJabatan  String           @map("nama_jabatan") @db.VarChar(200)
  unitKerja    String           @map("unit_kerja") @db.VarChar(200)
  tahun        Int

  nip          String?          @db.VarChar(20)
  namaAsn      String?          @map("nama_asn") @db.VarChar(200)
  pangkat      String?          @db.VarChar(100)
  golongan     String?          @db.VarChar(20)
  tmtJabatan   DateTime?        @map("tmt_jabatan")

  statusIsi    String           @default("VACANT") @map("status_isi") @db.VarChar(20)
  keterangan   String?          @db.Text

  createdAt    DateTime         @default(now()) @map("created_at")
  createdBy    String?          @map("created_by") @db.VarChar(36)
  updatedAt    DateTime         @updatedAt @map("updated_at")
  updatedBy    String?          @map("updated_by") @db.VarChar(36)

  @@index([tahun])
  @@index([unitKerja])
  @@index([statusIsi])
  @@map("siformen_bezetting")
}

model SiformenFormasi {
  id                    String           @id @default(uuid()) @db.VarChar(36)
  jabatanId             String?          @map("jabatan_id") @db.VarChar(36)
  jabatan               SiformenJabatan? @relation(fields: [jabatanId], references: [id], onDelete: SetNull)

  namaJabatan           String           @map("nama_jabatan") @db.VarChar(200)
  unitKerja             String           @map("unit_kerja") @db.VarChar(200)
  jenisFormasi          String           @map("jenis_formasi") @db.VarChar(20)
  tahun                 Int
  periode               String?          @db.VarChar(20)

  jumlahKebutuhan       Int              @default(0) @map("jumlah_kebutuhan")
  jumlahTersedia        Int              @default(0) @map("jumlah_tersedia")
  jumlahUsulan          Int              @default(0) @map("jumlah_usulan")

  kualifikasiPendidikan String?          @map("kualifikasi_pendidikan") @db.VarChar(200)
  kualifikasiJurusan    String?          @map("kualifikasi_jurusan") @db.VarChar(200)
  alasanKebutuhan       String?          @map("alasan_kebutuhan") @db.Text

  status                String           @default("DRAFT") @db.VarChar(20)
  catatanVerifikasi     String?          @map("catatan_verifikasi") @db.Text

  approvedById          String?          @map("approved_by_id") @db.VarChar(36)
  approvedAt            DateTime?        @map("approved_at")
  submittedAt           DateTime?        @map("submitted_at")

  createdAt             DateTime         @default(now()) @map("created_at")
  createdBy             String?          @map("created_by") @db.VarChar(36)
  updatedAt             DateTime         @updatedAt @map("updated_at")
  updatedBy             String?          @map("updated_by") @db.VarChar(36)
  deletedAt             DateTime?        @map("deleted_at")

  @@index([tahun])
  @@index([jenisFormasi])
  @@index([status])
  @@map("siformen_formasi")
}

model SiformenAbk {
  id               String           @id @default(uuid()) @db.VarChar(36)
  jabatanId        String?          @map("jabatan_id") @db.VarChar(36)
  jabatan          SiformenJabatan? @relation(fields: [jabatanId], references: [id], onDelete: SetNull)

  namaJabatan      String           @map("nama_jabatan") @db.VarChar(200)
  unitKerja        String           @map("unit_kerja") @db.VarChar(200)
  tahun            Int
  uraianTugas      String?          @map("uraian_tugas") @db.Text

  volumeKerja      Float            @map("volume_kerja")
  normaWaktu       Float            @map("norma_waktu")
  bebanKerja       Float            @map("beban_kerja")
  waktuEfektif     Float            @default(1250) @map("waktu_efektif")
  kebutuhanPegawai Float            @map("kebutuhan_pegawai")
  pegawaiAda       Int              @default(0) @map("pegawai_ada")
  selisih          Float            @default(0)
  keterangan       String?          @db.Text

  createdAt        DateTime         @default(now()) @map("created_at")
  createdBy        String?          @map("created_by") @db.VarChar(36)
  updatedAt        DateTime         @updatedAt @map("updated_at")
  updatedBy        String?          @map("updated_by") @db.VarChar(36)

  @@index([tahun])
  @@index([unitKerja])
  @@map("siformen_abk")
}

// ─── Pemberhentian / Pensiun (UU No. 20 Tahun 2023) ─────────────────────────

model PemberhentianProses {
  id                 String              @id @default(uuid()) @db.VarChar(36)
  asnId              String              @map("asn_id") @db.VarChar(36)
  jenisPemberhentian JenisPemberhentian  @map("jenis_pemberhentian")
  status             StatusPemberhentian @default(DRAFT)
  tmtPemberhentian   DateTime?           @map("tmt_pemberhentian") @db.Date
  nomorSk            String?             @map("nomor_sk") @db.VarChar(120)
  tanggalSk          DateTime?           @map("tanggal_sk") @db.Date
  nomorUsul          String?             @map("nomor_usul") @db.VarChar(120)
  tanggalUsul        DateTime?           @map("tanggal_usul") @db.Date
  nomorPengembalian  String?             @map("nomor_pengembalian") @db.VarChar(120)
  alasanPengembalian String?             @map("alasan_pengembalian") @db.Text
  catatan            String?             @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  asn           Asn                          @relation(fields: [asnId], references: [id], onDelete: Cascade)
  statusHistory PemberhentianStatusHistory[]
  dokumen       PemberhentianDokumen[]

  @@index([asnId])
  @@index([status])
  @@index([jenisPemberhentian])
  @@index([tmtPemberhentian])
  @@index([deletedAt])
  @@map("pemberhentian_proses")
}

model PemberhentianStatusHistory {
  id         String               @id @default(uuid()) @db.VarChar(36)
  prosesId   String               @map("proses_id") @db.VarChar(36)
  statusDari StatusPemberhentian? @map("status_dari")
  statusKe   StatusPemberhentian  @map("status_ke")
  catatan    String?              @db.Text
  createdAt  DateTime             @default(now()) @map("created_at")
  createdBy  String?              @map("created_by") @db.VarChar(36)

  proses PemberhentianProses @relation(fields: [prosesId], references: [id], onDelete: Cascade)

  @@index([prosesId])
  @@index([createdAt])
  @@map("pemberhentian_status_history")
}

model PemberhentianDokumen {
  id           String   @id @default(uuid()) @db.VarChar(36)
  prosesId     String   @map("proses_id") @db.VarChar(36)
  jenisDokumen String   @map("jenis_dokumen") @db.VarChar(120)
  namaFile     String   @map("nama_file") @db.VarChar(255)
  storagePath  String   @map("storage_path") @db.VarChar(512)
  fileSize     Int?     @map("file_size")
  mimeType     String?  @map("mime_type") @db.VarChar(80)
  keterangan   String?  @db.VarChar(300)
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by") @db.VarChar(36)
  updatedAt    DateTime @updatedAt @map("updated_at")

  proses PemberhentianProses @relation(fields: [prosesId], references: [id], onDelete: Cascade)

  @@index([prosesId])
  @@index([jenisDokumen])
  @@map("pemberhentian_dokumen")
}
