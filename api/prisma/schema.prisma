// ─── SIDATA ASN Import Staging ────────────────────────────────────────────────

model SidataAsnImportBatch {
  id            String    @id @db.VarChar(36)
  source        String    @db.VarChar(50)
  importType    String    @map("import_type") @db.VarChar(100)
  fileName      String?   @map("file_name") @db.VarChar(255)
  status        String    @db.VarChar(50)
  totalRows     Int       @default(0) @map("total_rows")
  validRows     Int       @default(0) @map("valid_rows")
  invalidRows   Int       @default(0) @map("invalid_rows")
  duplicateRows Int       @default(0) @map("duplicate_rows")
  warningRows   Int       @default(0) @map("warning_rows")
  importedById  String?   @map("imported_by_id") @db.VarChar(36)
  fileChecksum  String?   @map("file_checksum") @db.VarChar(64)
  startedAt     DateTime? @map("started_at")
  finishedAt    DateTime? @map("finished_at")
  errorMessage  String?   @map("error_message") @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  stagingRows       SidataAsnImportStaging[]
  currentAsn        Asn[]
  siasnProfiles     AsnSiasnProfile[]
  importSnapshots   AsnImportSnapshot[]
  assignmentHistory AsnAssignmentHistory[]
  golonganHistory   AsnGolonganHistory[]
  pendidikanHistory AsnPendidikanHistory[]

  @@index([source])
  @@index([importType])
  @@index([status])
  @@index([fileChecksum])
  @@index([createdAt])
  @@map("sidata_asn_import_batch")
}

model SidataAsnImportStaging {
  id        String @id @db.VarChar(36)
  batchId   String @map("batch_id") @db.VarChar(36)
  rowNumber Int    @map("row_number")

  // Core identity
  nip     String? @db.VarChar(30)
  nipLama String? @map("nip_lama") @db.VarChar(30)
  nama    String? @db.VarChar(300)

  // Jabatan
  namaJabatan    String?   @map("nama_jabatan") @db.VarChar(300)
  jenisJabatan   String?   @map("jenis_jabatan") @db.VarChar(100)
  kdJabatan      String?   @map("kd_jabatan") @db.VarChar(50)
  kdJabatanSiasn String?   @map("kd_jabatan_siasn") @db.VarChar(50)
  tmtJabatan     DateTime? @map("tmt_jabatan")

  // Golongan / Pangkat
  namaGolongan      String?   @map("nama_golongan") @db.VarChar(100)
  namaRuang         String?   @map("nama_ruang") @db.VarChar(100)
  kdGolongan        String?   @map("kd_golongan") @db.VarChar(20)
  kdGolonganSiasn   String?   @map("kd_golongan_siasn") @db.VarChar(20)
  tmtGolongan       DateTime? @map("tmt_golongan")
  masaKerjaGolongan String?   @map("masa_kerja_golongan") @db.VarChar(20)
  masaKerjaSeluruh  String?   @map("masa_kerja_seluruh") @db.VarChar(20)

  // Unit Organisasi
  namaUnorEselon1 String? @map("nama_unor_eselon1") @db.VarChar(300)
  namaUnorEselon2 String? @map("nama_unor_eselon2") @db.VarChar(300)
  namaUnorEselon3 String? @map("nama_unor_eselon3") @db.VarChar(300)
  namaUnorEselon4 String? @map("nama_unor_eselon4") @db.VarChar(300)
  kdUnor          String? @map("kd_unor") @db.VarChar(50)

  // Data Pribadi
  tempatLahir        String?   @map("tempat_lahir") @db.VarChar(100)
  tanggalLahir       DateTime? @map("tanggal_lahir")
  jenisKelamin       String?   @map("jenis_kelamin") @db.VarChar(20)
  agama              String?   @db.VarChar(50)
  statusKawin        String?   @map("status_kawin") @db.VarChar(50)
  pendidikanTerakhir String?   @map("pendidikan_terakhir") @db.VarChar(100)
  namaSekolah        String?   @map("nama_sekolah") @db.VarChar(300)

  // Status Kepegawaian
  tmtPns            DateTime? @map("tmt_pns")
  tmtPensiun        DateTime? @map("tmt_pensiun")
  statusKepegawaian String?   @map("status_kepegawaian") @db.VarChar(100)
  jenisAsn          String?   @map("jenis_asn") @db.VarChar(50)
  kedudukanHukum    String?   @map("kedudukan_hukum") @db.VarChar(100)

  // SK
  noSk      String?   @map("no_sk") @db.VarChar(100)
  tanggalSk DateTime? @map("tanggal_sk")

  // Validation & Mapping
  validationStatus String  @default("VALID") @map("validation_status") @db.VarChar(50)
  validationErrors Json?   @map("validation_errors")
  mappingStatus    String  @default("UNMAPPED") @map("mapping_status") @db.VarChar(50)
  matchedAsnId     String? @map("matched_asn_id") @db.VarChar(36)

  rawData    Json  @map("raw_data")
  mappedData Json? @map("mapped_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  batch SidataAsnImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([nip])
  @@index([nama])
  @@index([validationStatus])
  @@index([mappingStatus])
  @@index([createdAt])
  @@map("sidata_asn_import_staging")
}

model SidataImportAuditLog {
  id        String   @id @db.VarChar(36)
  batchId   String   @map("batch_id") @db.VarChar(36)
  batchType String   @map("batch_type") @db.VarChar(50)
  action    String   @db.VarChar(100)
  actorId   String?  @map("actor_id") @db.VarChar(36)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([batchId])
  @@index([batchType])
  @@index([action])
  @@index([actorId])
  @@index([createdAt])
  @@map("sidata_import_audit_log")
}

// ─────────────────────────────────────────────
// SOP Checklist Persistence (Sprint 14)
// ─────────────────────────────────────────────

model SopChecklistInstance {
  id             String    @id @default(cuid()) @db.VarChar(36)
  sopCode        String    @map("sop_code") @db.VarChar(50)
  moduleKey      String    @map("module_key") @db.VarChar(50)
  entityType     String    @map("entity_type") @db.VarChar(50)
  entityId       String    @map("entity_id") @db.VarChar(36)
  status         String    @default("DRAFT") @db.VarChar(30)
  progress       Int       @default(0)
  completedItems Int       @default(0) @map("completed_items")
  totalItems     Int       @default(0) @map("total_items")
  approvedById   String?   @map("approved_by_id") @db.VarChar(36)
  approvedAt     DateTime? @map("approved_at")
  rejectedById   String?   @map("rejected_by_id") @db.VarChar(36)
  rejectedAt     DateTime? @map("rejected_at")
  approvalNote   String?   @map("approval_note") @db.Text
  createdById    String?   @map("created_by_id") @db.VarChar(36)
  updatedById    String?   @map("updated_by_id") @db.VarChar(36)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  items     SopChecklistItem[]
  auditLogs SopChecklistAuditLog[]

  @@index([sopCode])
  @@index([moduleKey])
  @@index([entityType, entityId])
  @@index([status])
  @@index([createdAt])
  @@map("sop_checklist_instance")
}

model SopChecklistItem {
  id          String   @id @default(cuid()) @db.VarChar(36)
  instanceId  String   @map("instance_id") @db.VarChar(36)
  itemId      String   @map("item_id") @db.VarChar(100)
  status      String   @default("PENDING") @db.VarChar(30)
  notes       String?  @db.Text
  dmsDocumentId String? @map("dms_document_id") @db.VarChar(36)
  updatedById String?  @map("updated_by_id") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  instance SopChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([instanceId, itemId])
  @@index([instanceId])
  @@index([status])
  @@map("sop_checklist_item")
}

model SopChecklistAuditLog {
  id         String   @id @default(cuid()) @db.VarChar(36)
  instanceId String   @map("instance_id") @db.VarChar(36)
  actorId    String?  @map("actor_id") @db.VarChar(36)
  action     String   @db.VarChar(100)
  itemId     String?  @map("item_id") @db.VarChar(100)
  fromStatus String?  @map("from_status") @db.VarChar(30)
  toStatus   String?  @map("to_status") @db.VarChar(30)
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  instance SopChecklistInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("sop_checklist_audit_log")
}

