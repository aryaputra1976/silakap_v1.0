  @@index([targetId])
  @@index([sopId])
  @@index([rhkCode])
  @@index([year])
  @@index([month])
  @@index([quarter])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("kinerja_bidang_sop_realizations")
}

model KinerjaBidangSopEvidence {
  id            String @id @default(uuid()) @db.VarChar(36)
