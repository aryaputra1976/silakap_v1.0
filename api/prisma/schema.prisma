generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CaseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum CasePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TaskStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  WAITING
  RETURNED
  COMPLETED
  OVERDUE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum SlaStatus {
  ON_TRACK
  WARNING
  OVERDUE
  ESCALATED
  COMPLETED
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
  CANCELLED
}

enum SiapWorklogStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUIRED
  APPROVED
  REJECTED
}

enum JenisPensiun {
  BUP
  APS
  JDU
  TWS
  SAK
  HLG
  PTDH
  YATIM_PIATU
}

enum DmsDocumentCategory {
  SKP
  LAPORAN_BULANAN
  LAPORAN_TRIWULAN
  LAPORAN_TAHUNAN
  REKON_DATA
  DATA_ASN
  SURAT_DINAS
  NOTA_DINAS
  BUKTI_DUKUNG
  DOKUMEN_KEBIJAKAN
  ARSIP_KEPEGAWAIAN
  LAINNYA
}

enum DmsDocumentStatus {
  DRAFT
  UPLOADED
  SUBMITTED
  VERIFIED
  REJECTED
  ARCHIVED
}

model User {
  id           String        @id @default(uuid()) @db.VarChar(36)
  username     String        @unique @map("user") @db.VarChar(50)
  email        String?       @unique @db.VarChar(150)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  name         String        @db.VarChar(150)
  nip          String?       @unique @db.VarChar(30)
  phone        String?       @db.VarChar(30)
  status       AccountStatus @default(ACTIVE)

  unitKerjaId String?    @map("unit_kerja_id") @db.VarChar(36)
  unitKerja   UnitKerja? @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String?   @map("created_by") @db.VarChar(36)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by") @db.VarChar(36)
  deletedAt   DateTime? @map("deleted_at")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]

  assignedTasks SiapTask[] @relation("TaskAssignedTo")
  createdTasks  SiapTask[] @relation("TaskAssignedBy")

  workflowLogs          WorkflowLog[]
  timelineLogs          TimelineEntry[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  siapWorklogs          SiapWorklog[]   @relation("WorklogUser")
  reviewedSiapWorklogs  SiapWorklog[]   @relation("WorklogReviewer")
  createdDmsDocuments   DmsDocument[]   @relation("DmsDocumentCreatedBy")
  submittedDmsDocuments DmsDocument[]   @relation("DmsDocumentSubmittedBy")
  verifiedDmsDocuments  DmsDocument[]   @relation("DmsDocumentVerifiedBy")

  @@index([username])
  @@index([email])
  @@index([nip])
  @@index([unitKerjaId])
  @@index([status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.VarChar(36)
  code        String  @unique @db.VarChar(80)
  name        String  @db.VarChar(120)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([code])
  @@index([isActive])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.VarChar(36)
  code        String  @unique @db.VarChar(120)
  name        String  @db.VarChar(150)
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@index([isActive])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.VarChar(36)
  userId String @map("user_id") @db.VarChar(36)
  roleId String @map("role_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(36)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.VarChar(36)
  roleId       String @map("role_id") @db.VarChar(36)
  permissionId String @map("permission_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(36)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address") @db.VarChar(100)
  userAgent String?   @map("user_agent") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model UnitKerja {
  id       String  @id @default(uuid()) @db.VarChar(36)
  kode     String  @unique @db.VarChar(50)
  nama     String  @db.VarChar(200)
  parentId String? @map("parent_id") @db.VarChar(36)
  level    Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  parent   UnitKerja?  @relation("UnitKerjaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children UnitKerja[] @relation("UnitKerjaHierarchy")

  users        User[]
  asn          Asn[]
  siapWorklogs SiapWorklog[]
  dmsDocuments DmsDocument[]

  @@index([kode])
  @@index([parentId])
  @@index([isActive])
  @@map("unit_kerja")
}

model Asn {
  id    String  @id @default(uuid()) @db.VarChar(36)
  nip   String  @unique @db.VarChar(30)
  nik   String? @unique @db.VarChar(30)
  nama  String  @db.VarChar(200)
  email String? @db.VarChar(150)
  phone String? @db.VarChar(30)

  unitKerjaId String?    @map("unit_kerja_id") @db.VarChar(36)
  unitKerja   UnitKerja? @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)

  jabatanNama  String? @map("jabatan_nama") @db.VarChar(200)
  golonganNama String? @map("golongan_nama") @db.VarChar(100)
  jenisAsn     String? @map("jenis_asn") @db.VarChar(50)
  statusAsn    String? @map("status_asn") @db.VarChar(50)

  tanggalLahir DateTime? @map("tanggal_lahir")
  tmtPensiun   DateTime? @map("tmt_pensiun")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  cases          SiapCase[]
  sipensiunCases SipensiunCase[]
  dmsDocuments   DmsDocument[]

  @@index([nip])
  @@index([nama])
  @@index([unitKerjaId])
  @@index([statusAsn])
  @@index([tmtPensiun])
  @@map("asn")
}

model SiapCase {
  id           String       @id @default(uuid()) @db.VarChar(36)
  caseNumber   String       @unique @map("case_number") @db.VarChar(80)
  serviceType  String       @map("service_type") @db.VarChar(80)
  title        String       @db.VarChar(200)
  description  String?      @db.Text
  asnId        String?      @map("asn_id") @db.VarChar(36)
  currentState String       @default("DRAFT") @map("current_state") @db.VarChar(80)
  status       CaseStatus   @default(DRAFT)
  priority     CasePriority @default(NORMAL)

  submittedAt DateTime? @map("submitted_at")
  completedAt DateTime? @map("completed_at")
  closedAt    DateTime? @map("closed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  asn           Asn?            @relation(fields: [asnId], references: [id], onDelete: SetNull)
  tasks         SiapTask[]
  documents     Document[]
  workflowLogs  WorkflowLog[]
  slaTracking   SlaTracking[]
  timelines     TimelineEntry[]
  sipensiunCase SipensiunCase?
  notifications Notification[]
  worklogs      SiapWorklog[]
  dmsDocuments  DmsDocument[]

  @@index([caseNumber])
  @@index([serviceType])
  @@index([asnId])
  @@index([currentState])
  @@index([status])
  @@index([priority])
  @@map("siap_cases")
}

model SiapTask {
  id          String       @id @default(uuid()) @db.VarChar(36)
  caseId      String       @map("case_id") @db.VarChar(36)
  taskType    String       @map("task_type") @db.VarChar(80)
  title       String       @db.VarChar(200)
  description String?      @db.Text
  status      TaskStatus   @default(CREATED)
  priority    TaskPriority @default(NORMAL)

  assignedTo String? @map("assigned_to") @db.VarChar(36)
  assignedBy String? @map("assigned_by") @db.VarChar(36)

  dueDate     DateTime? @map("due_date")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  case        SiapCase        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  assignee    User?           @relation("TaskAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)
  assigner    User?           @relation("TaskAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)
  slaTracking SlaTracking[]
  timelines   TimelineEntry[]
  worklogs    SiapWorklog[]

  @@index([caseId])
  @@index([taskType])
  @@index([status])
  @@index([assignedTo])
  @@index([dueDate])
  @@map("siap_tasks")
}

model SiapWorklog {
  id          String  @id @default(uuid()) @db.VarChar(36)
  userId      String  @map("user_id") @db.VarChar(36)
  unitKerjaId String? @map("unit_kerja_id") @db.VarChar(36)
  caseId      String? @map("case_id") @db.VarChar(36)
  taskId      String? @map("task_id") @db.VarChar(36)

  workDate    DateTime          @map("work_date")
  category    String            @db.VarChar(80)
  title       String            @db.VarChar(200)
  description String            @db.Text
  output      String?           @db.Text
  volume      Int?
  obstacle    String?           @db.Text
  status      SiapWorklogStatus @default(DRAFT)

  submittedAt DateTime? @map("submitted_at")
  reviewedBy  String?   @map("reviewed_by") @db.VarChar(36)
  reviewedAt  DateTime? @map("reviewed_at")
  reviewNote  String?   @map("review_note") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  user         User                    @relation("WorklogUser", fields: [userId], references: [id], onDelete: Cascade)
  unitKerja    UnitKerja?              @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)
  case         SiapCase?               @relation(fields: [caseId], references: [id], onDelete: SetNull)
  task         SiapTask?               @relation(fields: [taskId], references: [id], onDelete: SetNull)
  reviewer     User?                   @relation("WorklogReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attachments  SiapWorklogAttachment[]
  dmsDocuments DmsDocument[]

  @@index([userId])
  @@index([unitKerjaId])
  @@index([caseId])
  @@index([taskId])
  @@index([workDate])
  @@index([category])
  @@index([status])
  @@index([submittedAt])
  @@index([reviewedBy])
  @@map("siap_worklogs")
}

model WorkflowDefinition {
  id          String  @id @default(uuid()) @db.VarChar(36)
  code        String  @unique @db.VarChar(80)
  name        String  @db.VarChar(150)
  serviceType String  @map("service_type") @db.VarChar(80)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transitions WorkflowTransition[]

  @@index([code])
  @@index([serviceType])
  @@index([isActive])
  @@map("workflow_definitions")
}

model WorkflowTransition {
  id         String @id @default(uuid()) @db.VarChar(36)
  workflowId String @map("workflow_id") @db.VarChar(36)

  fromState   String @map("from_state") @db.VarChar(80)
  toState     String @map("to_state") @db.VarChar(80)
  actionCode  String @map("action_code") @db.VarChar(80)
  allowedRole String @map("allowed_role") @db.VarChar(80)

  slaDays   Int?    @map("sla_days")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([fromState])
  @@index([toState])
  @@index([actionCode])
  @@index([allowedRole])
  @@map("workflow_transitions")
}

model WorkflowLog {
  id          String   @id @default(uuid()) @db.VarChar(36)
  caseId      String   @map("case_id") @db.VarChar(36)
  fromState   String?  @map("from_state") @db.VarChar(80)
  toState     String   @map("to_state") @db.VarChar(80)
  action      String   @db.VarChar(80)
  note        String?  @db.Text
  performedBy String?  @map("performed_by") @db.VarChar(36)
  performedAt DateTime @default(now()) @map("performed_at")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.Text

  case SiapCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User?    @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([performedBy])
  @@index([action])
  @@index([performedAt])
  @@map("workflow_logs")
}

model SlaTracking {
  id            String    @id @default(uuid()) @db.VarChar(36)
  caseId        String    @map("case_id") @db.VarChar(36)
  taskId        String?   @map("task_id") @db.VarChar(36)
  workflowState String    @map("workflow_state") @db.VarChar(80)
  startedAt     DateTime  @map("started_at")
  dueAt         DateTime  @map("due_at")
  completedAt   DateTime? @map("completed_at")
  status        SlaStatus @default(ON_TRACK)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  case SiapCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  task SiapTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([taskId])
  @@index([workflowState])
  @@index([dueAt])
  @@index([status])
  @@map("sla_tracking")
}

model Document {
  id               String   @id @default(uuid()) @db.VarChar(36)
  caseId           String?  @map("case_id") @db.VarChar(36)
  documentType     String   @map("document_type") @db.VarChar(100)
  fileName         String   @map("file_name") @db.VarChar(255)
  originalFileName String?  @map("original_file_name") @db.VarChar(255)
  storagePath      String   @map("storage_path") @db.VarChar(500)
  mimeType         String?  @map("mime_type") @db.VarChar(120)
  fileSize         Int?     @map("file_size")
  checksum         String?  @db.VarChar(128)
  version          Int      @default(1)
  uploadedBy       String?  @map("uploaded_by") @db.VarChar(36)
  uploadedAt       DateTime @default(now()) @map("uploaded_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  case               SiapCase?               @relation(fields: [caseId], references: [id], onDelete: SetNull)
  worklogAttachments SiapWorklogAttachment[]

  @@index([caseId])
  @@index([documentType])
  @@index([uploadedBy])
  @@map("documents")
}

model TimelineEntry {
  id          String   @id @default(uuid()) @db.VarChar(36)
  caseId      String   @map("case_id") @db.VarChar(36)
  taskId      String?  @map("task_id") @db.VarChar(36)
  eventType   String   @map("event_type") @db.VarChar(100)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  performedBy String?  @map("performed_by") @db.VarChar(36)
  createdAt   DateTime @default(now()) @map("created_at")

  case SiapCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  task SiapTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user User?     @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([taskId])
  @@index([performedBy])
  @@index([eventType])
  @@index([createdAt])
  @@map("timeline_entries")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.VarChar(36)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    String   @map("entity_id") @db.VarChar(100)
  action      String   @db.VarChar(100)
  performedBy String?  @map("performed_by") @db.VarChar(36)
  beforeData  Json?    @map("before_data")
  afterData   Json?    @map("after_data")
  ipAddress   String?  @map("ip_address") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([performedBy])
  @@index([createdAt])
  @@map("audit_logs")
}

model DomainEvent {
  id           String      @id @default(uuid()) @db.VarChar(36)
  eventType    String      @map("event_type") @db.VarChar(120)
  entityType   String      @map("entity_type") @db.VarChar(100)
  entityId     String      @map("entity_id") @db.VarChar(100)
  payload      Json?
  status       EventStatus @default(PENDING)
  retryCount   Int         @default(0) @map("retry_count")
  errorMessage String?     @map("error_message") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")
  processedAt  DateTime?   @map("processed_at")

  @@index([eventType])
  @@index([entityType])
  @@index([entityId])
  @@index([status])
  @@index([createdAt])
  @@map("domain_events")
}

model Notification {
  id     String  @id @default(uuid()) @db.VarChar(36)
  userId String? @map("user_id") @db.VarChar(36)
  caseId String? @map("case_id") @db.VarChar(36)

  type      String  @db.VarChar(80)
  title     String  @db.VarChar(200)
  body      String? @db.Text
  actionUrl String? @map("action_url") @db.VarChar(300)
  metadata  Json?

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)

  user User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  case SiapCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([caseId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@map("notifications")
}

model SipensiunCase {
  id           String       @id @default(uuid()) @db.VarChar(36)
  siapCaseId   String       @unique @map("siap_case_id") @db.VarChar(36)
  asnId        String       @map("asn_id") @db.VarChar(36)
  jenisPensiun JenisPensiun @map("jenis_pensiun")
  tmtPensiun   DateTime?    @map("tmt_pensiun")
  catatan      String?      @db.Text

  nomorKarpeg          String? @map("nomor_karpeg") @db.VarChar(80)
  alamatSekarang       String? @map("alamat_sekarang") @db.Text
  alamatSesudahPensiun String? @map("alamat_sesudah_pensiun") @db.Text
  noHp                 String? @map("no_hp") @db.VarChar(40)

  namaPemohon     String? @map("nama_pemohon") @db.VarChar(150)
  nikPemohon      String? @map("nik_pemohon") @db.VarChar(40)
  hubunganPemohon String? @map("hubungan_pemohon") @db.VarChar(80)
  alamatPemohon   String? @map("alamat_pemohon") @db.Text
  noHpPemohon     String? @map("no_hp_pemohon") @db.VarChar(40)

  namaPenerimaManfaat String?   @map("nama_penerima_manfaat") @db.VarChar(150)
  tanggalMeninggal    DateTime? @map("tanggal_meninggal")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  siapCase SiapCase @relation(fields: [siapCaseId], references: [id], onDelete: Cascade)
  asn      Asn      @relation(fields: [asnId], references: [id], onDelete: Cascade)

  @@index([asnId])
  @@index([jenisPensiun])
  @@index([tmtPensiun])
  @@map("sipensiun_cases")
}

model SiapWorklogAttachment {
  id         String @id @default(uuid()) @db.VarChar(36)
  worklogId  String @map("worklog_id") @db.VarChar(36)
  documentId String @map("document_id") @db.VarChar(36)

  label       String?  @db.VarChar(150)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by") @db.VarChar(36)

  worklog  SiapWorklog @relation(fields: [worklogId], references: [id], onDelete: Cascade)
  document Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([worklogId, documentId])
  @@index([worklogId])
  @@index([documentId])
  @@index([createdAt])
  @@map("siap_worklog_attachments")
}

model DmsDocument {
  id          String              @id @default(uuid()) @db.VarChar(36)
  title       String              @db.VarChar(200)
  description String?             @db.Text
  category    DmsDocumentCategory @default(BUKTI_DUKUNG)
  status      DmsDocumentStatus   @default(DRAFT)

  periodYear    Int? @map("period_year")
  periodMonth   Int? @map("period_month")
  periodQuarter Int? @map("period_quarter")

  unitKerjaId String? @map("unit_kerja_id") @db.VarChar(36)
  asnId       String? @map("asn_id") @db.VarChar(36)
  caseId      String? @map("case_id") @db.VarChar(36)
  worklogId   String? @map("worklog_id") @db.VarChar(36)

  fileName         String? @map("file_name") @db.VarChar(255)
  originalFileName String? @map("original_file_name") @db.VarChar(255)
  storagePath      String? @map("storage_path") @db.VarChar(500)
  mimeType         String? @map("mime_type") @db.VarChar(120)
  fileSize         Int?    @map("file_size")
  checksum         String? @db.VarChar(128)
  version          Int     @default(1)

  submittedAt   DateTime? @map("submitted_at")
  submittedById String?   @map("submitted_by_id") @db.VarChar(36)

  verifiedAt   DateTime? @map("verified_at")
  verifiedById String?   @map("verified_by_id") @db.VarChar(36)

  rejectedAt    DateTime? @map("rejected_at")
  rejectionNote String?   @map("rejection_note") @db.Text

  archivedAt DateTime? @map("archived_at")

  createdAt   DateTime  @default(now()) @map("created_at")
  createdById String?   @map("created_by_id") @db.VarChar(36)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedById String?   @map("updated_by_id") @db.VarChar(36)
  deletedAt   DateTime? @map("deleted_at")

  unitKerja UnitKerja?   @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)
  asn       Asn?         @relation(fields: [asnId], references: [id], onDelete: SetNull)
  case      SiapCase?    @relation(fields: [caseId], references: [id], onDelete: SetNull)
  worklog   SiapWorklog? @relation(fields: [worklogId], references: [id], onDelete: SetNull)

  createdBy   User? @relation("DmsDocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  submittedBy User? @relation("DmsDocumentSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  verifiedBy  User? @relation("DmsDocumentVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([title])
  @@index([category])
  @@index([status])
  @@index([periodYear])
  @@index([periodMonth])
  @@index([periodQuarter])
  @@index([unitKerjaId])
  @@index([asnId])
  @@index([caseId])
  @@index([worklogId])
  @@index([createdById])
  @@index([submittedById])
  @@index([verifiedById])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("dms_documents")
}
