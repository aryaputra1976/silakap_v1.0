model KinerjaBidangSopRealization {
  id       String @id @default(uuid()) @db.VarChar(36)
  targetId String @map("target_id") @db.VarChar(36)
  sopId    String @map("sop_id") @db.VarChar(36)
  rhkCode  String @map("rhk_code") @db.VarChar(30)

  year    Int
  month   Int?
  quarter Int?

  realizationQuantity Int                  @default(0) @map("realization_quantity")
  qualityPercent      Float?               @map("quality_percent")
  timeStatus          String?              @map("time_status") @db.VarChar(80)
  status              SopRealizationStatus @default(DRAFT)

  title       String  @db.VarChar(250)
  description String? @db.Text
  constraint  String? @db.Text
  followUp    String? @map("follow_up") @db.Text
  reviewNote  String? @map("review_note") @db.Text

  submittedAt DateTime? @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  approvedAt  DateTime? @map("approved_at")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  target   KinerjaBidangSopTarget     @relation(fields: [targetId], references: [id], onDelete: Cascade)
  sop      KinerjaBidangSop           @relation(fields: [sopId], references: [id], onDelete: Cascade)
