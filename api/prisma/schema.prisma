model SidataAsnImportStaging {
  id        String @id @db.VarChar(36)
  batchId   String @map("batch_id") @db.VarChar(36)
  rowNumber Int    @map("row_number")

  // Core identity
  nip     String? @db.VarChar(30)
  nipLama String? @map("nip_lama") @db.VarChar(30)
  nama    String? @db.VarChar(300)

  // Jabatan
  namaJabatan    String?   @map("nama_jabatan") @db.VarChar(300)
  jenisJabatan   String?   @map("jenis_jabatan") @db.VarChar(100)
  kdJabatan      String?   @map("kd_jabatan") @db.VarChar(50)
  kdJabatanSiasn String?   @map("kd_jabatan_siasn") @db.VarChar(50)
  tmtJabatan     DateTime? @map("tmt_jabatan")

  // Golongan / Pangkat
  namaGolongan      String?   @map("nama_golongan") @db.VarChar(100)
  namaRuang         String?   @map("nama_ruang") @db.VarChar(100)
  kdGolongan        String?   @map("kd_golongan") @db.VarChar(20)
  kdGolonganSiasn   String?   @map("kd_golongan_siasn") @db.VarChar(20)
  tmtGolongan       DateTime? @map("tmt_golongan")
  masaKerjaGolongan String?   @map("masa_kerja_golongan") @db.VarChar(20)
  masaKerjaSeluruh  String?   @map("masa_kerja_seluruh") @db.VarChar(20)

  // Unit Organisasi
  namaUnorEselon1 String? @map("nama_unor_eselon1") @db.VarChar(300)
  namaUnorEselon2 String? @map("nama_unor_eselon2") @db.VarChar(300)
  namaUnorEselon3 String? @map("nama_unor_eselon3") @db.VarChar(300)
  namaUnorEselon4 String? @map("nama_unor_eselon4") @db.VarChar(300)
  kdUnor          String? @map("kd_unor") @db.VarChar(50)

  // Data Pribadi
  tempatLahir        String?   @map("tempat_lahir") @db.VarChar(100)
  tanggalLahir       DateTime? @map("tanggal_lahir")
  jenisKelamin       String?   @map("jenis_kelamin") @db.VarChar(20)
  agama              String?   @db.VarChar(50)
  statusKawin        String?   @map("status_kawin") @db.VarChar(50)
  pendidikanTerakhir String?   @map("pendidikan_terakhir") @db.VarChar(100)
  namaSekolah        String?   @map("nama_sekolah") @db.VarChar(300)

  // Status Kepegawaian
  tmtPns            DateTime? @map("tmt_pns")
  tmtPensiun        DateTime? @map("tmt_pensiun")
  statusKepegawaian String?   @map("status_kepegawaian") @db.VarChar(100)
  jenisAsn          String?   @map("jenis_asn") @db.VarChar(50)
  kedudukanHukum    String?   @map("kedudukan_hukum") @db.VarChar(100)

  // SK
  noSk      String?   @map("no_sk") @db.VarChar(100)
  tanggalSk DateTime? @map("tanggal_sk")

  // Validation & Mapping
  validationStatus String  @default("VALID") @map("validation_status") @db.VarChar(50)
  validationErrors Json?   @map("validation_errors")
  mappingStatus    String  @default("UNMAPPED") @map("mapping_status") @db.VarChar(50)
  matchedAsnId     String? @map("matched_asn_id") @db.VarChar(36)

  rawData    Json  @map("raw_data")
  mappedData Json? @map("mapped_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  batch SidataAsnImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([nip])
  @@index([nama])
  @@index([validationStatus])
  @@index([mappingStatus])
  @@index([createdAt])
  @@map("sidata_asn_import_staging")
}

