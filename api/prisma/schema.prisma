generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum CaseStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum CasePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum TaskStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  WAITING
  RETURNED
  COMPLETED
  OVERDUE
  CANCELLED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum SlaStatus {
  ON_TRACK
  WARNING
  OVERDUE
  ESCALATED
  COMPLETED
}

enum EventStatus {
  PENDING
  PROCESSED
  FAILED
  CANCELLED
}

enum SiapWorklogStatus {
  DRAFT
  SUBMITTED
  REVISION_REQUIRED
  APPROVED
  REJECTED
}

enum JenisPensiun {
  BUP
  APS
  JDU
  TWS
  SAK
  HLG
  PTDH
  YATIM_PIATU
}

enum JenisPemberhentian {
  // Atas Permintaan Sendiri
  APS
  // Tidak Atas Permintaan - Dengan Hormat
  DH_BUP
  DH_BERAKHIR_PPPK
  DH_MENINGGAL
  DH_PERAMPINGAN
  DH_TIDAK_CAKAP
  DH_TIDAK_KINERJA
  // Tidak Atas Permintaan - Tidak Dengan Hormat
  TDH_PANCASILA
  TDH_DISIPLIN
  TDH_PIDANA
  TDH_PARPOL
  // Pemberhentian Sementara
  SEM_PEJABAT_NEGARA
  SEM_KOMISIONER
  SEM_CLTN
  SEM_DITAHAN
}

enum StatusPemberhentian {
  DRAFT
  PENGUMPULAN_BERKAS
  VERIFIKASI_BERKAS
  NOTA_USUL
  DIKIRIM_BKN
  PROSES_BKN
  SK_TERBIT
  DIKEMBALIKAN
  SELESAI
  DIBATALKAN
}

enum DmsDocumentCategory {
  SKP
  LAPORAN_BULANAN
  LAPORAN_TRIWULAN
  LAPORAN_TAHUNAN
  REKON_DATA
  DATA_ASN
  SURAT_DINAS
  NOTA_DINAS
  BUKTI_DUKUNG
  DOKUMEN_KEBIJAKAN
  ARSIP_KEPEGAWAIAN
  LAINNYA
}

enum DmsDocumentStatus {
  DRAFT
  UPLOADED
  SUBMITTED
  VERIFIED
  REJECTED
  ARCHIVED
}

enum SopStage {
  TAHAP_1
  TAHAP_2
  TAHAP_3
}

enum SopStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum SopTargetUnit {
  LAPORAN
  DOKUMEN
}

enum SopRealizationStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  APPROVED
  REVISION_REQUIRED
}

model User {
  id           String        @id @default(uuid()) @db.VarChar(36)
  username     String        @unique @map("user") @db.VarChar(50)
  email        String?       @unique @db.VarChar(150)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  name         String        @db.VarChar(150)
  nip          String?       @unique @db.VarChar(30)
  phone        String?       @db.VarChar(30)
  status       AccountStatus @default(ACTIVE)

  unitKerjaId String?    @map("unit_kerja_id") @db.VarChar(36)
  unitKerja   UnitKerja? @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String?   @map("created_by") @db.VarChar(36)
  updatedAt   DateTime  @updatedAt @map("updated_at")
  updatedBy   String?   @map("updated_by") @db.VarChar(36)
  deletedAt   DateTime? @map("deleted_at")

  userRoles     UserRole[]
  refreshTokens RefreshToken[]

  assignedTasks SiapTask[] @relation("TaskAssignedTo")
  createdTasks  SiapTask[] @relation("TaskAssignedBy")

  workflowLogs          WorkflowLog[]
  timelineLogs          TimelineEntry[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  siapWorklogs          SiapWorklog[]   @relation("WorklogUser")
  reviewedSiapWorklogs  SiapWorklog[]   @relation("WorklogReviewer")
  createdDmsDocuments   DmsDocument[]   @relation("DmsDocumentCreatedBy")
  submittedDmsDocuments DmsDocument[]   @relation("DmsDocumentSubmittedBy")
  verifiedDmsDocuments  DmsDocument[]   @relation("DmsDocumentVerifiedBy")

  @@index([username])
  @@index([email])
  @@index([nip])
  @@index([unitKerjaId])
  @@index([status])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.VarChar(36)
  code        String  @unique @db.VarChar(80)
  name        String  @db.VarChar(120)
  description String? @db.Text
  isSystem    Boolean @default(false) @map("is_system")
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([code])
  @@index([isActive])
  @@map("roles")
}

model Permission {
  id          String  @id @default(uuid()) @db.VarChar(36)
  code        String  @unique @db.VarChar(120)
  name        String  @db.VarChar(150)
  resource    String  @db.VarChar(100)
  action      String  @db.VarChar(50)
  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@index([isActive])
  @@map("permissions")
}

model UserRole {
  id     String @id @default(uuid()) @db.VarChar(36)
  userId String @map("user_id") @db.VarChar(36)
  roleId String @map("role_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(36)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(uuid()) @db.VarChar(36)
  roleId       String @map("role_id") @db.VarChar(36)
  permissionId String @map("permission_id") @db.VarChar(36)

  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by") @db.VarChar(36)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  ipAddress String?   @map("ip_address") @db.VarChar(100)
  userAgent String?   @map("user_agent") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model UnitKerja {
  id        String  @id @default(uuid()) @db.VarChar(36)
  kode      String  @unique @db.VarChar(50)
  nama      String  @db.VarChar(200)
  parentId  String? @map("parent_id") @db.VarChar(36)
  level     Int     @default(0)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") @db.VarChar(36)
  updatedAt DateTime  @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(36)
  deletedAt DateTime? @map("deleted_at")

  parent   UnitKerja?  @relation("UnitKerjaHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children UnitKerja[] @relation("UnitKerjaHierarchy")

  users                User[]
  asn                  Asn[]
  asnAssignmentHistory AsnAssignmentHistory[]
  siapWorklogs         SiapWorklog[]
  dmsDocuments         DmsDocument[]

  @@index([kode])
  @@index([parentId])
  @@index([sortOrder])
  @@index([isActive])
  @@map("unit_kerja")
}

model Asn {
  id            String  @id @default(uuid()) @db.VarChar(36)
  siasnPnsId    String? @map("siasn_pns_id") @db.VarChar(60)
  nip           String  @unique @db.VarChar(30)
  nipLama       String? @map("nip_lama") @db.VarChar(30)
  nik           String? @unique @db.VarChar(30)
  nama          String  @db.VarChar(200)
  namaSearch    String? @map("nama_search") @db.VarChar(250)
  gelarDepan    String? @map("gelar_depan") @db.VarChar(80)
  gelarBelakang String? @map("gelar_belakang") @db.VarChar(120)

  tipePegawai         String?            @map("tipe_pegawai") @db.VarChar(30)
  jenisAsnRefId       String?            @map("jenis_asn_ref_id") @db.VarChar(36)
  jenisAsnNama        String?            @map("jenis_asn_nama") @db.VarChar(180)
  statusAsn           String?            @map("status_asn") @db.VarChar(120)
  isActive            Boolean            @default(true) @map("is_active")
  kedudukanHukumRefId String?            @map("kedudukan_hukum_ref_id") @db.VarChar(36)
  kedudukanHukumNama  String?            @map("kedudukan_hukum_nama") @db.VarChar(120)
  tmtPensiun          DateTime?          @map("tmt_pensiun")
  jenisAsnRef         RefJenisAsn?       @relation(fields: [jenisAsnRefId], references: [id], onDelete: SetNull)
  kedudukanHukumRef   RefKedudukanHukum? @relation(fields: [kedudukanHukumRefId], references: [id], onDelete: SetNull)

  unitKerjaId String?    @map("unit_kerja_id") @db.VarChar(36)
  siasnUnorId String?    @map("siasn_unor_id") @db.VarChar(60)
  unorNama    String?    @map("unor_nama") @db.VarChar(300)
  unitKerja   UnitKerja? @relation(fields: [unitKerjaId], references: [id], onDelete: SetNull)

  jabatanRefId     String?     @map("jabatan_ref_id") @db.VarChar(36)
  siasnJabatanId   String?     @map("siasn_jabatan_id") @db.VarChar(60)
  jabatanNama      String?     @map("jabatan_nama") @db.VarChar(300)
  jenisJabatanNama String?     @map("jenis_jabatan_nama") @db.VarChar(100)
  tmtJabatan       DateTime?   @map("tmt_jabatan")
  jabatanRef       RefJabatan? @relation(fields: [jabatanRefId], references: [id], onDelete: SetNull)

  golonganRefId   String?      @map("golongan_ref_id") @db.VarChar(36)
  siasnGolonganId String?      @map("siasn_golongan_id") @db.VarChar(60)
  golonganNama    String?      @map("golongan_nama") @db.VarChar(100)
  tmtGolongan     DateTime?    @map("tmt_golongan")
  golonganRef     RefGolongan? @relation(fields: [golonganRefId], references: [id], onDelete: SetNull)

  masaKerjaTahun      Int? @map("masa_kerja_tahun")
  masaKerjaBulan      Int? @map("masa_kerja_bulan")
  masaKerjaTotalBulan Int? @map("masa_kerja_total_bulan")
  kelasJabatan        Int? @map("kelas_jabatan")

  siasnEselonId String?    @map("siasn_eselon_id") @db.VarChar(30)
  eselonRefId   String?    @map("eselon_ref_id") @db.VarChar(36)
  eselonNama    String?    @map("eselon_nama") @db.VarChar(80)
  eselonRef     RefEselon? @relation(fields: [eselonRefId], references: [id], onDelete: SetNull)

  namaUnorEselon1 String? @map("nama_unor_eselon1") @db.VarChar(300)
  namaUnorEselon2 String? @map("nama_unor_eselon2") @db.VarChar(300)
  namaUnorEselon3 String? @map("nama_unor_eselon3") @db.VarChar(300)
  namaUnorEselon4 String? @map("nama_unor_eselon4") @db.VarChar(300)

  pangkatNama String? @map("pangkat_nama") @db.VarChar(120)
  ruangNama   String? @map("ruang_nama") @db.VarChar(80)

  nomorSk    String?   @map("nomor_sk") @db.VarChar(120)
  tanggalSk  DateTime? @map("tanggal_sk")

  nomorPerjanjianKerja   String?   @map("nomor_perjanjian_kerja") @db.VarChar(120)
  tmtPerjanjianKerja     DateTime? @map("tmt_perjanjian_kerja")
  akhirPerjanjianKerja   DateTime? @map("akhir_perjanjian_kerja")
  masaHubunganKerjaBulan Int?      @map("masa_hubungan_kerja_bulan")

  jenisPegawaiNama String? @map("jenis_pegawai_nama") @db.VarChar(180)
  detailStatusNama String? @map("detail_status_nama") @db.VarChar(180)

  pendidikanRefId        String?                 @map("pendidikan_ref_id") @db.VarChar(36)
  pendidikanNama         String?                 @map("pendidikan_nama") @db.VarChar(180)
  tingkatPendidikanRefId String?                 @map("tingkat_pendidikan_ref_id") @db.VarChar(36)
  tingkatPendidikanNama  String?                 @map("tingkat_pendidikan_nama") @db.VarChar(120)
  tahunLulus             Int?                    @map("tahun_lulus")
  namaSekolah            String?                 @map("nama_sekolah") @db.VarChar(300)
  pendidikanRef          RefPendidikan?          @relation("AsnCurrentPendidikan", fields: [pendidikanRefId], references: [id], onDelete: SetNull)
  tingkatPendidikanRef   RefPendidikanTingkat?   @relation("AsnCurrentTingkatPendidikan", fields: [tingkatPendidikanRefId], references: [id], onDelete: SetNull)

  sourceBatchId String?               @map("source_batch_id") @db.VarChar(36)
  syncedAt      DateTime?             @map("synced_at")
  checksum      String?               @db.VarChar(128)
  syncStatus    String                @default("SYNCED") @map("sync_status") @db.VarChar(40)
  lastSiasnBatchId String?            @map("last_siasn_batch_id") @db.VarChar(36)
  lastSiasnSyncedAt DateTime?         @map("last_siasn_synced_at")
  localCorrectionAt DateTime?         @map("local_correction_at")
  localCorrectionBy String?           @map("local_correction_by") @db.VarChar(36)
  localCorrectionReason String?       @map("local_correction_reason") @db.Text
  needsReview   Boolean               @default(false) @map("needs_review")
  reviewNote    String?               @map("review_note") @db.Text
  createdAt     DateTime              @default(now()) @map("created_at")
  createdBy     String?               @map("created_by") @db.VarChar(36)
  updatedAt     DateTime              @updatedAt @map("updated_at")
  updatedBy     String?               @map("updated_by") @db.VarChar(36)
  deletedAt     DateTime?             @map("deleted_at")
  sourceBatch   SidataAsnImportBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  cases                SiapCase[]
  sipensiunCases       SipensiunCase[]
  dmsDocuments         DmsDocument[]
  documents            Document[]
  pemberhentianProses  PemberhentianProses[]

  siasnProfile      AsnSiasnProfile?
  importSnapshots   AsnImportSnapshot[]
  assignmentHistory AsnAssignmentHistory[]
  golonganHistory   AsnGolonganHistory[]
  pendidikanHistory AsnPendidikanHistory[]
  monthlyChanges    AsnMonthlyChange[]
  monthlySnapshots  AsnMonthlySnapshot[]
  changeLogs        AsnChangeLog[]

  @@index([nip])
  @@index([nama])
  @@index([namaSearch])
  @@index([unitKerjaId])
  @@index([jabatanRefId])
  @@index([golonganRefId])
  @@index([jenisAsnRefId])
  @@index([kedudukanHukumRefId])
  @@index([tipePegawai])
  @@index([statusAsn])
  @@index([isActive])
  @@index([tmtPensiun])
  @@index([kelasJabatan])
  @@index([siasnEselonId])
  @@index([eselonRefId])
  @@index([akhirPerjanjianKerja])
  @@index([pendidikanRefId])
  @@index([tingkatPendidikanRefId])
  @@index([masaKerjaTotalBulan])
  @@index([siasnPnsId])
  @@index([siasnJabatanId])
  @@index([siasnUnorId])
  @@index([sourceBatchId])
  @@index([syncedAt])
  @@index([checksum])
  @@index([syncStatus])
  @@index([lastSiasnBatchId])
  @@index([lastSiasnSyncedAt])
  @@index([localCorrectionAt])
  @@index([localCorrectionBy])
  @@index([needsReview])
  @@index([deletedAt, unitKerjaId])
  @@index([deletedAt, tipePegawai])
  @@map("asn")
}

model AsnChangeLog {
  id                 String   @id @default(uuid()) @db.VarChar(36)
  asnId              String   @map("asn_id") @db.VarChar(36)
  fieldName          String   @map("field_name") @db.VarChar(120)
  oldValue           String?  @map("old_value") @db.Text
  newValue           String?  @map("new_value") @db.Text
  changedBy          String?  @map("changed_by") @db.VarChar(36)
  changedAt          DateTime @default(now()) @map("changed_at")
  reason             String?  @db.Text
  evidenceDocumentId String?  @map("evidence_document_id") @db.VarChar(36)
  source             String   @default("MANUAL") @db.VarChar(60)
  sourceBatchId      String?  @map("source_batch_id") @db.VarChar(36)
  metadata           Json?

  asn Asn @relation(fields: [asnId], references: [id], onDelete: Cascade)

  @@index([asnId])
  @@index([fieldName])
  @@index([changedBy])
  @@index([changedAt])
  @@index([source])
  @@index([sourceBatchId])
  @@index([evidenceDocumentId])
  @@map("asn_change_log")
}

model AsnSiasnProfile {
  id            String  @id @default(uuid()) @db.VarChar(36)
  asnId         String  @unique @map("asn_id") @db.VarChar(36)
  sourceBatchId String? @map("source_batch_id") @db.VarChar(36)
  siasnPnsId    String? @map("siasn_pns_id") @db.VarChar(60)

  email     String? @db.VarChar(150)
  emailGov  String? @map("email_gov") @db.VarChar(150)
  phone     String? @db.VarChar(30)
  alamat    String? @db.Text
  npwpNomor String? @map("npwp_nomor") @db.VarChar(50)
  bpjsNomor String? @map("bpjs_nomor") @db.VarChar(50)

  tempatLahirId   String?   @map("tempat_lahir_id") @db.VarChar(60)
  tempatLahirNama String?   @map("tempat_lahir_nama") @db.VarChar(120)
  tanggalLahir    DateTime? @map("tanggal_lahir")

  jenisKelaminRefId   String?          @map("jenis_kelamin_ref_id") @db.VarChar(36)
  siasnJenisKelaminId String?          @map("siasn_jenis_kelamin_id") @db.VarChar(30)
  jenisKelaminNama    String?          @map("jenis_kelamin_nama") @db.VarChar(50)
  jenisKelaminRef     RefJenisKelamin? @relation(fields: [jenisKelaminRefId], references: [id], onDelete: SetNull)

  agamaRefId   String?   @map("agama_ref_id") @db.VarChar(36)
  siasnAgamaId String?   @map("siasn_agama_id") @db.VarChar(30)
  agamaNama    String?   @map("agama_nama") @db.VarChar(80)
  agamaRef     RefAgama? @relation(fields: [agamaRefId], references: [id], onDelete: SetNull)

  statusKawinRefId   String?         @map("status_kawin_ref_id") @db.VarChar(36)
  siasnStatusKawinId String?         @map("siasn_status_kawin_id") @db.VarChar(30)
  statusKawinNama    String?         @map("status_kawin_nama") @db.VarChar(80)
  statusKawinRef     RefStatusKawin? @relation(fields: [statusKawinRefId], references: [id], onDelete: SetNull)

  siasnJenisPegawaiId   String?            @map("siasn_jenis_pegawai_id") @db.VarChar(30)
  jenisPegawaiNama      String?            @map("jenis_pegawai_nama") @db.VarChar(180)
  kedudukanHukumRefId   String?            @map("kedudukan_hukum_ref_id") @db.VarChar(36)
  siasnKedudukanHukumId String?            @map("siasn_kedudukan_hukum_id") @db.VarChar(30)
  kedudukanHukumNama    String?            @map("kedudukan_hukum_nama") @db.VarChar(120)
  statusCpnsPns         String?            @map("status_cpns_pns") @db.VarChar(20)
  kartuAsnVirtual       String?            @map("kartu_asn_virtual") @db.VarChar(80)
  kedudukanHukumRef     RefKedudukanHukum? @relation(fields: [kedudukanHukumRefId], references: [id], onDelete: SetNull)

  nomorSkCpns   String?   @map("nomor_sk_cpns") @db.VarChar(120)
  tanggalSkCpns DateTime? @map("tanggal_sk_cpns")
  tmtCpns       DateTime? @map("tmt_cpns")
  nomorSkPns    String?   @map("nomor_sk_pns") @db.VarChar(120)
  tanggalSkPns  DateTime? @map("tanggal_sk_pns")
  tmtPns        DateTime? @map("tmt_pns")
  tmtPensiun    DateTime? @map("tmt_pensiun")

  kpknId               String? @map("kpkn_id") @db.VarChar(60)
  kpknNama             String? @map("kpkn_nama") @db.VarChar(180)
  lokasiKerjaId        String? @map("lokasi_kerja_id") @db.VarChar(60)
  lokasiKerjaNama      String? @map("lokasi_kerja_nama") @db.VarChar(180)
  siasnUnorId          String? @map("siasn_unor_id") @db.VarChar(60)
  unorNama             String? @map("unor_nama") @db.VarChar(300)
  instansiIndukId      String? @map("instansi_induk_id") @db.VarChar(60)
  instansiIndukNama    String? @map("instansi_induk_nama") @db.VarChar(180)
  instansiKerjaId      String? @map("instansi_kerja_id") @db.VarChar(60)
  instansiKerjaNama    String? @map("instansi_kerja_nama") @db.VarChar(180)
  satuanKerjaIndukId   String? @map("satuan_kerja_induk_id") @db.VarChar(60)
  satuanKerjaIndukNama String? @map("satuan_kerja_induk_nama") @db.VarChar(180)
  satuanKerjaKerjaId   String? @map("satuan_kerja_kerja_id") @db.VarChar(60)
  satuanKerjaKerjaNama String? @map("satuan_kerja_kerja_nama") @db.VarChar(180)

  isValidNik String? @map("is_valid_nik") @db.VarChar(10)
  flagIkd    String? @map("flag_ikd") @db.VarChar(10)

  profileData Json?     @map("profile_data")
  rawData     Json      @map("raw_data")
  checksum    String?   @db.VarChar(128)
  syncedAt    DateTime  @default(now()) @map("synced_at")
