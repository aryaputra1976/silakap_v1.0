  @@unique([sopId, rhkCode])
  @@index([sopId])
  @@index([rhkCode])
  @@map("kinerja_bidang_sop_rhk")
}

model KinerjaBidangSopStep {
  id    String @id @default(uuid()) @db.VarChar(36)
  sopId String @map("sop_id") @db.VarChar(36)

  stepNumber Int     @map("step_number")
