{
  "name": "silakap",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:api": "npm --prefix api run dev",
    "dev:web": "npm --workspace apps/web run dev",
